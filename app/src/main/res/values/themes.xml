<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose-only launcher: inherits from the platform Material theme (API 21+),
         no MDC library required. -->
    <style name="Theme.PFP" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- Pre-Compose frame: the wave gradient's deep top blue, so the system splash blends
             straight into the boot wave instead of flashing black. -->
        <item name="android:windowBackground">#0743A2</item>
    </style>
</resources>
