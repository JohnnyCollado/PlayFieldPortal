<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- ROM files on primary storage (/storage/emulated/0) passed to emulators -->
    <external-path name="roms" path="." />

    <!-- ROMs on any mounted volume — removable SD cards and USB drives live under
         /storage/<volume-uuid>/... (e.g. /storage/408C-3861/...), which <external-path>
         does NOT cover. Without this, FileProvider.getUriForFile throws
         "Failed to find configured root" and the launch fails before the intent is sent. -->
    <root-path name="storage_volumes" path="/storage/" />

    <!-- Theme packs and backups in the PlayFieldPortal folder -->
    <external-path name="pfp_root" path="PlayFieldPortal/" />

    <!-- Internal cache — used for temporary file passing to emulators -->
    <cache-path name="cache" path="." />

    <!-- Scraped artwork/manuals (filesDir/artwork/). Currently unused: manuals render in-app
         via PdfRenderer (ManualViewerOverlay), so no content URI is minted for them. Kept only
         until a share/external-viewer feature needs it — safe to remove otherwise. -->
    <files-path name="artwork" path="artwork/" />
</paths>
