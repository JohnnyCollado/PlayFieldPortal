<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ═══ Permissions ════════════════════════════════════════════════ -->

    <!-- Storage — needed for ROM scanning and PlayFieldPortal/ folder -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- API 33+ scoped storage — declared in runtime permission request -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <!-- Required for full PlayFieldPortal/ folder access on API 30+ -->
    <!-- Google Play justification: users install .xmbtheme packs and backups here -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <!-- Launcher role — see all installed apps -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <!-- Internet — SteamGridDB, emulator profile updates -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Restore state on boot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- WorkManager background tasks -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Capture legacy game shortcuts from apps that still use the old broadcast
         (BannerHub, older Winlator). The modern path is LauncherApps shortcut harvesting. -->
    <uses-permission android:name="com.android.launcher.permission.INSTALL_SHORTCUT" />

    <!-- Playtime tracking -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Controller input -->
    <uses-feature android:name="android.hardware.gamepad" android:required="false" />

    <application
        android:name=".PFPApplication"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/Theme.PFP"
        android:supportsRtl="true"
        android:hardwareAccelerated="true">

        <!-- ═══ Launcher Activity ═══════════════════════════════════════ -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden|keyboard|navigation"
            android:windowSoftInputMode="stateAlwaysHidden">

            <!-- HOME intent — this makes PFP a launcher -->
            <intent-filter android:priority="1">
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <!-- Standard launcher entry point -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ═══ Pinned-shortcut confirmation ═══════════════════════════════ -->
        <!-- Declaring this makes PFP advertise pin support so apps using the modern
             requestPinShortcut() (BannerHub, modern Winlator) can create game shortcuts.
             Invisible: it accepts the pin, records the entry, and finishes. -->
        <activity
            android:name=".pin.PinShortcutActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.content.pm.action.CONFIRM_PIN_SHORTCUT" />
            </intent-filter>
        </activity>

        <!-- ═══ Legacy INSTALL_SHORTCUT capture (BannerHub, old Winlator) ═══ -->
        <!-- Best-effort manifest registration. Android 8+ blocks this implicit broadcast for
             background manifest receivers, so MainActivity also registers it at runtime. -->
        <receiver
            android:name=".receiver.InstallShortcutReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.android.launcher.action.INSTALL_SHORTCUT" />
            </intent-filter>
        </receiver>

        <!-- ═══ Boot Receiver ════════════════════════════════════════════ -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- ═══ Package Change Receiver (emulator install/uninstall) ════ -->
        <receiver
            android:name=".receiver.PackageChangeReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <action android:name="android.intent.action.PACKAGE_REMOVED" />
                <action android:name="android.intent.action.PACKAGE_REPLACED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

        <!-- ═══ WorkManager ══════════════════════════════════════════════ -->
        <!-- On-demand init: PFPApplication is the Configuration.Provider (Hilt-Work), so the -->
        <!-- default WorkManagerInitializer must be removed from the startup provider.        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                tools:node="remove" />
        </provider>

        <!-- ═══ Music playback foreground service ══════════════════════ -->
        <!-- Keeps in-app music playing (with a media notification) while the user is in other
             apps. Started on-demand from the player's "Play in Background". -->
        <service
            android:name="com.playfieldportal.feature.xmb.music.MusicPlaybackService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- ═══ FileProvider — ROM URIs passed to emulators ════════════ -->
        <!-- EmulatorIntentResolver uses this to build content:// URIs    -->
        <!-- that emulators can read without MANAGE_EXTERNAL_STORAGE       -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
